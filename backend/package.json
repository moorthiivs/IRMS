{
  "name": "irms-backend",
  "version": "1.0.0",
  "description": "Manufacturing Inspection Report Management System Backend",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npx prisma generate && nest build",
    "build:all": "cd ../frontend && npm run build && xcopy /E /I /Y dist ..\\backend\\client && cd ../backend && npm run build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/main",
    "prestart": "npx prisma generate && npx prisma migrate resolve --rolled-back 20260709000000_add_customer_id_and_poka_yoke || true && npx prisma migrate deploy",
    "start:local": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "prestart:prod": "npx prisma generate && npx prisma migrate resolve --rolled-back 20260709000000_add_customer_id_and_poka_yoke || true && npx prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node prisma/seed.ts",
    "seed": "npm run prisma:seed"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.1.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/serve-static": "^4.0.2",
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.1",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.22.0",
    "prisma": "^5.22.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.18.5/xlsx-0.18.5.tgz"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^4.17.17",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^3.0.9",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
